# corralai demo — environment knobs
# Copy this to .env (gitignored) and set values as needed.
# Most knobs are OPTIONAL — the demo runs key-free out of the box.

# ---------------------------------------------------------------------------
# Ollama — model storage
# ---------------------------------------------------------------------------

# Reuse models already pulled on your host machine (skips the Docker volume pull).
# Set this to ~/.ollama and the demo will use your existing local models.
# Default: a named Docker volume (ollama-models) — models are pulled on first run.
# OLLAMA_MODELS_DIR=~/.ollama

# Point agents at a different Ollama instance (e.g. your host's Ollama).
# Default: the bundled container (http://ollama:11434).
# OLLAMA_URL=http://host.docker.internal:11434

# ---------------------------------------------------------------------------
# Default swarm model (make demo / make demo-mission)
# ---------------------------------------------------------------------------

# Backend: ollama | openai (OpenAI-compatible: Gemini, OpenRouter, vLLM, ...)
# Default: ollama
# MODEL_BACKEND=ollama

# Model name for the chosen backend.
# Default: qwen2.5-coder:7b
# AGENT_MODEL=qwen2.5-coder:7b

# ---------------------------------------------------------------------------
# API keys — only needed to swap to frontier models
# ---------------------------------------------------------------------------

# OpenAI / OpenAI-compatible key (Gemini via its OpenAI endpoint, OpenRouter, etc.)
# Required only if MODELS_BACKEND_A=openai or MODEL_BACKEND=openai.
OPENAI_API_KEY=

# Anthropic key — only needed if MODEL_BACKEND=anthropic.
# ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# demo-models — multi-model A-vs-B comparison
# ---------------------------------------------------------------------------
# Default is fully key-free (both groups use local Ollama):
#   Group A (pentester): qwen2.5-coder:7b
#   Group B (reviewer):  llama3.2:3b
#
# For a frontier-vs-local comparison, override Group A:
#   MODELS_BACKEND_A=openai
#   MODELS_MODEL_A=gemini-3.5-flash   # requires OPENAI_API_KEY above
#   OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#
# Or override both groups for the most striking side-by-side:
#   MODELS_BACKEND_A=openai
#   MODELS_MODEL_A=gemini-2.5-flash
#   MODELS_BACKEND_B=openai
#   MODELS_MODEL_B=gpt-4o

# MODELS_BACKEND_A=ollama
# MODELS_MODEL_A=qwen2.5-coder:7b
# MODELS_BACKEND_B=ollama
# MODELS_MODEL_B=llama3.2:3b

# OpenAI-compatible base URL (Gemini, OpenRouter, vLLM, LM Studio, …)
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# ---------------------------------------------------------------------------
# Reference RAG (optional — off by default)
# ---------------------------------------------------------------------------
# Set these to enable the brain's semantic search over uploaded documents.
# Without them, the brain logs a graceful "embeddings disabled" notice.
# CORRALAI_EMBED_URL=https://generativelanguage.googleapis.com/v1beta/openai/embeddings
# CORRALAI_EMBED_KEY=   # your Gemini or OpenAI key

# ---------------------------------------------------------------------------
# MotherDuck / DuckDB (optional)
# ---------------------------------------------------------------------------
# Connect the brain's telemetry store to MotherDuck for persistent analytics.
# CORRALAI_MOTHERDUCK_TOKEN=

# ---------------------------------------------------------------------------
# Git integration (optional)
# ---------------------------------------------------------------------------
# Personal access token for repo-work missions (checkout, push, PR creation).
# CORRALAI_GIT_TOKEN=
