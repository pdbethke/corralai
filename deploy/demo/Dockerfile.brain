# The corral brain (coordination + memory MCP server). CGO is required for the
# DuckDB-backed memory half, so we build on the full golang image and ship on a
# slim debian with libstdc++ + curl (for the healthcheck).
# Pin the build base to bookworm so the binary's glibc matches the slim runtime
# below (golang:1.26's default base is newer and links GLIBC_2.38).
FROM golang:1.26-bookworm AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=1 go build -trimpath -o /out/corral ./cmd/corral
# The operator client rides along so `docker compose exec brain corral-admin …`
# (analyze, status, review, instruct) works out of the box.
RUN CGO_ENABLED=0 go build -trimpath -o /out/corral-admin ./cmd/corral-admin

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates libstdc++6 curl git chromium \
    && rm -rf /var/lib/apt/lists/*
COPY --from=build /out/corral /usr/local/bin/corral
COPY --from=build /out/corral-admin /usr/local/bin/corral-admin
# Seed the swarm's shared memory with the self-describing meta-entry, so a fresh
# corpus starts non-empty and agents learn the hive-mind from the hive-mind. The
# brain re-indexes ~/.claude/projects/*/memory on startup (memStore.Build).
RUN mkdir -p /root/.claude/projects/default/memory
COPY deploy/demo/seed-memory/ /root/.claude/projects/default/memory/
# The CORRAL.md convention: seed the demo's own developer-doc corpus (CORRAL.md
# + docs/corral/*.md) into the same memory dir, flattened alongside seed-memory,
# so the demo boots with corralai's own pre-seeded docs already searchable.
COPY CORRAL.md docs/corral/ /root/.claude/projects/default/memory/
ENV CORRALAI_ADDR=0.0.0.0:9019
EXPOSE 9019
ENTRYPOINT ["corral"]
