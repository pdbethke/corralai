[19.925315, "o", "\r\nadversarial verdict — passwd.ts @ local\r\n  language:      typescript\r\n  status:        NEEDS-REVIEW (dev suite killed 1/5 mutants)\r\n  dev_kill_rate: 0.20\r\n  survivors:     4\r\n  proven_missed: 4\r\n  critic review: 1 test(s) flagged — UNVERIFIED (a second model's opinion, not execution-proven; check before acting)\r\n  models:        mutant-generator=claude-sonnet-5  test-critic=claude-haiku-4-5  test-writer=claude-sonnet-5\r\n  signed:        record 1\r\n      • [high] passwd.ts: The test \"valid length\" passes the string \"Abcdefgh1!xy\" (12 characters: A, b, c, d, e, f, g, h, 1, !, x, y) to valid(). This string contains an uppercase letter (A), lowercase letters (b-h, x, y), a digit (1), and a symbol (!). The function correctly returns true. However, the test name and assertion do not reveal whether the implementation properly validates ALL four required character types or merely checks length. The test passes regardless of whether the symbol-detection logic (the final else-if checking /[^A-Za-z0-9]/) is present, disabled, or broken—the string satisfies all requirements, so the assertion cannot fail even if symbol validation were removed entirely.\r\n\r\n"]
[19.925363, "o", "the herd authored a test that catches a gap your suite missed — add it to passwd.test.ts:\r\n\r\nimport { test } from 'node:test';\r\nimport assert from 'node:assert';\r\nimport { valid } from './passwd.ts';\r\n\r\ntest('rejects length between 8 and 11 even with all char classes (kills m1)', () => {\r\n  // length 11, has upper, lower, digit, symbol\r\n  const p = 'Ab1!Ab1!Ab1'.slice(0, 11);\r\n  assert.strictEqual(p.length, 11);\r\n  assert.strictEqual(valid(p), false);\r\n});\r\n\r\ntest('requires a symbol character even when length/up/lo/di satisfied (kills m2)', () => {\r\n  const p = 'Abcdefghij1'; // length 11\r\n  const p12 = 'Abcdefghij12'; // length 12, no symbol\r\n  assert.strictEqual(p12.length, 12);\r\n  assert.strictEqual(valid(p12), false);\r\n});\r\n\r\ntest('digit-only chars must not count as uppercase (kills m4)', () => {\r\n  // No actual uppercase letter, but contains digits, lowercase, symbol\r\n  const p = 'abcdefghij1!'; // length 12, lower+digit+symbol, no real uppercase\r\n  assert.strictEqual(p.length, 12);\r\n  assert.strictEqual(valid(p), false);\r\n});\r\n\r\ntest('requires ALL char classes, not just one (kills m5)', () => {\r\n  // length >= 12, only lowercase letters, no upper/digit/symbol\r\n  const p = 'abcdefghijkl';\r\n  assert.strictEqual(p.length, 12);\r\n  assert.strictEqual(valid(p), false);\r\n});\r\n\r\ntest('accepts a genuinely valid password meeting all requirements', () => {\r\n  const p = 'Abcdefghij1!'; // length 12, has upper, lower, digit, symbol\r\n  assert.strictEqual(p.length, 12);\r\n  assert.strictEqual(valid(p), true);\r\n});\r\n"]
