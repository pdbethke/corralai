{
  "name": "corralai-dev-site",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "predev": "node scripts/build-analytics.mjs",
    "prebuild": "bash ../scripts/sync-site-assets.sh --check && node scripts/build-analytics.mjs",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "astro": "ASTRO_TELEMETRY_DISABLED=1 astro",
    "test:e2e": "npm run build && npx playwright test"
  },
  "dependencies": {
    "@astrojs/starlight": "0.41.3",
    "astro": "7.0.6"
  },
  "devDependencies": {
    "@duckdb/node-api": "1.5.4-r.1",
    "@playwright/test": "1.61.1"
  }
}
