  .hero-breakdown[open] .chev { transform: rotate(180deg); }

  .bd-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px 26px; padding: 4px 18px 8px; }
  .bd-block.bd-wide { grid-column: 1 / -1; }
  .bd-block h4 { margin: 0 0 8px; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--amber); }
  .bd-block dl { margin: 0; display: flex; flex-direction: column; gap: 8px; }
  .bd-block dl > div { display: grid; grid-template-columns: 190px 1fr; gap: 12px; align-items: baseline; }
  .bd-block dt { color: var(--muted); font-size: 0.86rem; }
  .bd-block dd { margin: 0; color: var(--fg); font-size: 0.92rem; }
  .bd-block dd code, .bd-block dt code { font-family: ui-monospace, monospace; font-size: 0.85em; background: var(--sel); border-radius: 4px; padding: 1px 5px; }
  .bd-block .tag { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.03em; color: var(--green); border: 1px solid var(--green); border-radius: 999px; padding: 1px 7px; margin-left: 6px; vertical-align: middle; }
  .bd-block ul { margin: 0; padding-left: 18px; display: flex; flex-direction: column; gap: 7px; }
  .bd-block li { color: var(--fg); font-size: 0.94rem; line-height: 1.55; }
  .bd-block strong.ok { color: var(--green); }
  .bd-block strong.review { color: var(--amber); }
  .bd-ev { color: var(--muted); font-style: italic; }
  .bd-link { display: inline-block; margin: 4px 18px 16px; font-weight: 600; font-size: 0.92rem; text-decoration: none; color: var(--amber); }
  .bd-link:hover { text-decoration: underline; }

  @media (max-width: 720px) {
    .bd-grid { grid-template-columns: 1fr; }
    .bd-block dl > div { grid-template-columns: 1fr; gap: 2px; }
    .vs-herd { margin-left: 0; width: 100%; }
  }
  #empty { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; color: var(--stage-muted); pointer-events: none; }
  /* Bottom panel of the instrument — a child of #stage-frame, so it inherits
     the same content width (and 20px side gutters) as the console/cockpit and
     its left/right borders line up exactly. No own max-width/margin. */
  #replay {
    position: relative; background: var(--stage-panel); color: var(--stage-fg);
    border: 1px solid var(--stage-line); border-top: none;
