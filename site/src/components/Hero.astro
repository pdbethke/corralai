<!-- Pin the branded 'ranch' skin BEFORE the player loads: replay-player.js
     applies a persisted skin synchronously at its own load, and the skin the
     visitor may have picked on /recordings persists under the same corral-skin
     key on this origin. data-skin-lock makes the hero ignore that persisted
     pick (and not overwrite it) so the landing page always leads with the
     brand look. Must run before the player <script src>. -->
<script is:inline>document.documentElement.setAttribute('data-skin-lock', 'ranch');</script>
<script src="/replay-player.js" is:inline></script>
<script define:vars={{ golden }} is:inline>
  // The site's minimal DOM contract implementation (see replay-player.js's
  // header): only 'replay' exists here, so setView just needs to keep the
  // control bar visible — there is no tab system to dispatch between.
  //
  // NOTE: Astro's define:vars wraps this whole script body in an IIFE to
  // scope `golden`, so a plain `function setView(v){}` declaration would be
  // local to that closure, not global — and replay-player.js calls the
  // bare global `setView(...)`. Must assign to window explicitly.
  // The tabs are real: cockpitView() (replay-player.js) switches the cockpit to
  // the selected view, reducing the recorded tape into progress/topology/
  // completed and a labeled sample for the never-recorded memory/skills/
  // proposals — the same panels the live app shows, from the same shared code.
  window.setView = function (v) {
    if (typeof cockpitView === 'function') cockpitView(v);
    // The HUD's #stat defaults to the live cockpit's "connecting…" — there is
    // no live brain here, so pin it to an honest static label. The speed number
    // now lives in the #hud-speed dropdown right beside it ("replaying [ 2× ]").
    const stat = document.getElementById('stat');
    if (stat) stat.textContent = 'replaying';
  };
  // The cockpit HUD's #skinsel calls the shared setSkin, which repaints the
  // canvas/panels in the picked palette (matrix → green phosphor, etc.) AND
  // clobbers document.title with the product's skin subtitle — restore the
  // site's own title after each pick so the tab stays branded.
  const HERO_TITLE = 'Corralai — a headless brain for a herd of AI agents';
  if (typeof window.setSkin === 'function') {
    const _setSkin = window.setSkin;
    window.setSkin = function (v) { _setSkin(v); document.title = HERO_TITLE; };
  }
  window.addEventListener('DOMContentLoaded', () => {
    startReplay(golden).then(() => {
      // Activate the canvas tab (the shell hardcodes the hidden #tab-records
      // active; cockpitView doesn't manage it) so the visible "corral" tab
      // reads as selected, matching the stage that's showing.
      if (typeof cockpitView === 'function') cockpitView('swarm');
      // Cinematic auto-advance. The built-in autoplay fires one beat every
      // 250/speed ms (~2.4s for this short pool tape) and then FREEZES — far too
      // fast to see the herd work, and static by the time a visitor looks. So we
      // drive the scrubber ourselves at a watchable cadence, hold on the signed
      // verdict, and loop: the landing always shows the reasoning trace
      // revealing beat by beat. The moment the visitor touches the controls we
      // stop and hand playback over to them.
      const scrub = document.getElementById('replay-scrub');
      const playbtn = document.getElementById('replay-playbtn');
      if (!scrub || typeof seekReplay !== 'function') { toggleReplayPlay(); return; }
      let cinematic = true;
      const stop = () => { cinematic = false; };
      scrub.addEventListener('pointerdown', stop);
      scrub.addEventListener('keydown', stop);
      if (playbtn) playbtn.addEventListener('click', stop);
      const total = Number(scrub.max) || 0;
      const BEAT = 900, HOLD = 4200, LOOP_GAP = 1000;
      let i = 0;
      const tick = () => {
        if (!cinematic) return;
        i += 1;
        if (i > total) { i = 0; seekReplay(0); setTimeout(tick, LOOP_GAP); return; }
        seekReplay(i);
        setTimeout(tick, i === total ? HOLD : BEAT);
      };
      tick();
    });
  });
  // replay-player.js's setSkin() (run synchronously at its own script-load
  // time, before this block even executes) clobbers document.title to
  // 'CorralAI — the corral' — the product UI's own title, not the site's.
  // Restore the site's title here, verbatim against the <title> in
  // index.astro so this and the a11y "has a <title>" check never drift.
  document.title = 'Corralai — a headless brain for a herd of AI agents';
</script>
