---
// SPDX-License-Identifier: Elastic-2.0
import { cockpitHud, cockpitViews, cockpitTasks, cockpitAgents, cockpitFindings, cockpitExec } from '../lib/cockpitShell';
import ReplayBarControls from './ReplayBarControls.astro';

const generatedRecordings = import.meta.glob('../data/generated/recordings/*.json', { eager: true });
const legacyRecordings = import.meta.glob('../data/recordings/*.json', { eager: true });
const hasGeneratedRecordings = Object.keys(generatedRecordings).some(
  (p) => p.endsWith('.json') && !p.endsWith('.meta.json'),
);
const preferredRecordings = hasGeneratedRecordings ? generatedRecordings : legacyRecordings;
const fallbackRecordings = hasGeneratedRecordings ? legacyRecordings : {};
const heroSlug = (process.env.CORRALAI_HERO_SLUG || 'more-itertools-reliable-critic').trim() || 'more-itertools-reliable-critic';

function readRecordingModule(modules: Record<string, any>, slug: string, suffix: string) {
  const key = Object.keys(modules).find((p) => p.endsWith(`/${slug}${suffix}`));
  if (!key) return undefined;
  const mod = modules[key];
  return mod?.default ?? mod;
}

const golden =
  readRecordingModule(preferredRecordings, heroSlug, '.json') ??
  readRecordingModule(fallbackRecordings, heroSlug, '.json');
const meta =
  readRecordingModule(preferredRecordings, heroSlug, '.meta.json') ??
  readRecordingModule(fallbackRecordings, heroSlug, '.meta.json');
if (!golden || !meta) {
  throw new Error(
    `hero recording slug "${heroSlug}" not found in generated or legacy recordings`,
  );
}

const minutes = Math.round((meta.duration_seconds || 0) / 60);

// Every hero tape is an adversarial-pool audit: its signed verdict — a
// kill-rate + survivors, not a task/finding count — is the real story. Read it
// straight off the tape so the caption is data-driven and can't drift from the
// recording. The generic step-count caption is a defensive fallback only (no
// audit tape should ever hit it).
const events = Array.isArray(golden.events) ? golden.events : [];
const poolVerdict = events.find((e: any) => e?.kind === 'pool_verdict')?.detail;
const poolSubject = events.find((e: any) => e?.kind === 'pool_subject')?.detail;
// The critic's flags are advisory (never gate the verdict) — surface the count
// and the first one's evidence so the breakdown shows the herd's actual output.
const criticFindings = events
  .filter((e: any) => e?.kind === 'finding_reported' && e?.detail?.role === 'test-critic')
  .map((e: any) => e.detail);
const caughtN =
  poolVerdict && poolVerdict.mutants_total != null && poolVerdict.survivors != null
    ? poolVerdict.mutants_total - poolVerdict.survivors
    : null;
const pool = poolVerdict
  ? {
      codePath: poolSubject?.code_path || 'the change',
      goal: poolSubject?.goal || '',
      devTestPath: poolSubject?.dev_test_path || '',
      mutants: poolVerdict.mutants_total,
      survivors: poolVerdict.survivors,
      caught: caughtN,
      killPct:
        poolVerdict.dev_kill_rate != null
          ? Math.round(poolVerdict.dev_kill_rate * 100)
          : caughtN != null && poolVerdict.mutants_total
            ? Math.round((caughtN / poolVerdict.mutants_total) * 100)
            : null,
      planter: poolVerdict.models_by_role?.['mutant-generator'],
      writer: poolVerdict.models_by_role?.['test-writer'],
      critic: poolVerdict.models_by_role?.['test-critic'],
      provenMissed: poolVerdict.proven_missed || 0,
      certified: poolVerdict.status === 'certified',
      statusLabel: poolVerdict.status === 'certified' ? 'CERTIFIED' : 'NEEDS-REVIEW',
      criticCount: criticFindings.length,
      criticEvidence: (criticFindings[0]?.evidence || '').trim(),
      recordId: poolVerdict.record_id,
    }
  : null;
---
<section id="hero">
  <div class="hero-copy hero-top">
    <h1>No one may be judge in their own cause.</h1>
    <p class="latin"><em>Nemo iudex in causa sua.</em></p>
    <p class="lead">So Corral doesn't <em>build</em> your code — it <em>certifies a change by execution</em>: a decorrelated herd grades the tests meant to guard it, in a jail, and signs a tamper-evident verdict. Not a builder — a gate.</p>
    <div class="ctas">
      <a class="cta" href="https://github.com/pdbethke/corralai">View on GitHub</a>
      <a class="cta secondary" id="watch-demo-cta" href="#" style="display:none">Watch the demo</a>
    </div>
    {pool ? (
      <p class="caption">
        {/* single line: Astro collapses a text→newline→expression boundary to ZERO chars, so keep interpolations inline */}
        Below is a real run, replaying now: a <em>decorrelated</em> cross-vendor herd put <code>{pool.codePath}</code> to its own tests — {pool.planter} planted {pool.mutants} faults and a <em>different</em> model, {pool.critic}, graded whether the suite catches them. It caught {pool.caught}, missed {pool.survivors}. Signed <strong>{pool.statusLabel}</strong>{pool.provenMissed > 0 ? ', and the herd handed back a test that catches the gap' : ''}.
      </p>
    ) : (
      <p class="caption">
        Below is a real run, replaying now — {minutes}m, every step scrubbable.
      </p>
    )}
  </div>
  <div id="stage-frame">
    <div class="cockpit-hud" set:html={cockpitHud} />
    <div id="cockpit">
      <aside class="cockpit-tasks" set:html={cockpitTasks} />
      <div id="stage">
        <canvas id="c"></canvas>
        <div id="empty">no agents in the corral yet</div>
      </div>
      <aside class="cockpit-side">
        <div class="cockpit-agents" set:html={cockpitAgents} />
        <div class="cockpit-findings" set:html={cockpitFindings} />
      </aside>
      <div set:html={cockpitViews} />
    </div>
    <div class="cockpit-exec" set:html={cockpitExec} />
    <!-- The scrubber/controls bar is the LAST panel of the instrument, kept
         INSIDE #stage-frame so it shares the exact same content width and
         aligned left/right borders as the console/cockpit above it (a former
         sibling floated 40px wider — the misaligned bottom edge). -->
    <div id="replay">
      <div class="row">
        <span id="replay-title"></span>
        <button id="replay-playbtn" onclick="toggleReplayPlay()">▶ play</button>
        <input type="range" id="replay-scrub" min="0" max="0" value="0" oninput="seekReplay(+this.value)">
        <span id="replay-label">0 / 0</span>
        <ReplayBarControls />
      </div>
    </div>
  </div>
  {pool && (
    <div class="hero-copy hero-breakdown-wrap">
      <div class="verdict-strip">
        <span class={`vs-status ${pool.certified ? 'is-cert' : 'is-review'}`}>{pool.statusLabel}</span>
        <span class="vs-file"><code>{pool.codePath}</code></span>
        <span class="vs-metric"><strong>{pool.caught}/{pool.mutants}</strong> faults caught{pool.killPct != null ? ` · ${pool.killPct}% kill-rate` : ''}</span>
        <span class="vs-herd">{pool.planter}{pool.critic && pool.critic !== pool.planter ? ` + ${pool.critic}` : ''}</span>
      </div>
      <details class="hero-breakdown">
        <summary><span>What you just watched — the full breakdown</span><span class="chev" aria-hidden="true">▾</span></summary>
        <div class="bd-grid">
          <section class="bd-block">
            <h4>What was tested</h4>
            <dl>
              <div><dt>Code under audit</dt><dd><code>{pool.codePath}</code></dd></div>
              {pool.goal && <div><dt>The goal it must satisfy</dt><dd>“{pool.goal}”</dd></div>}
              {pool.devTestPath && <div><dt>Graded by</dt><dd><code>{pool.devTestPath}</code> — the library’s own tests</dd></div>}
            </dl>
          </section>
          <section class="bd-block">
            <h4>The decorrelated herd</h4>
            <dl>
              <div><dt>Planted the faults</dt><dd>{pool.planter}</dd></div>
              {pool.writer && <div><dt>Wrote exposing tests</dt><dd>{pool.writer}</dd></div>}
              <div><dt>Critiqued the suite <span class="tag">different model</span></dt><dd>{pool.critic}</dd></div>
            </dl>
          </section>
          <section class="bd-block bd-wide">
            <h4>What happened, in a jail</h4>
            <ul>
              <li>Planted <strong>{pool.mutants}</strong> goal-violating mutants across the file.</li>
              <li>Ran the developer’s own suite against every one — it killed <strong>{pool.caught} of {pool.mutants}</strong>{pool.killPct != null ? ` (a ${pool.killPct}% kill-rate)` : ''}, measured by execution, not asserted.</li>
              <li>Verdict: <strong class={pool.certified ? 'ok' : 'review'}>{pool.statusLabel}</strong> — signed and offline-verifiable{pool.provenMissed > 0 ? ', and the herd handed back a compiling test that kills the gap' : ''}.</li>
            </ul>
          </section>
          <section class="bd-block bd-wide">
            <h4>What it does — and doesn’t — claim</h4>
            <ul>
              <li><strong>{pool.survivors} survivor{pool.survivors === 1 ? '' : 's'}</strong> disclosed, <em>unadjudicated</em>: an injected mutant the suite didn’t kill — a real untested edge, <em>or</em> an equivalent mutant nothing can catch. Corral hands it to a human to judge; it doesn’t rule a well-loved library buggy.</li>
              {pool.criticCount > 0 && (
                <li>The decorrelated critic flagged <strong>{pool.criticCount}</strong> possible dead test{pool.criticCount === 1 ? '' : 's'} — <em>advisory, unverified, and structurally barred from gating the signed verdict</em>.{pool.criticEvidence && <span class="bd-ev"> {pool.criticEvidence.slice(0, 200)}…</span>}</li>
              )}
            </ul>
          </section>
        </div>
        <a class="bd-link" href={`/recordings/#${heroSlug}`}>Replay the full run and open the tests tab →</a>
      </details>
    </div>
  )}
  <div class="hero-copy hero-bottom">
    <p class="proof-row">
      <span>Certified <em>by execution</em> — run in a jail, not taken on a model's word</span>
      <span aria-hidden="true">·</span>
      <span><em>Decorrelated</em> — the judge is never the author; enforced, not hoped</span>
      <span aria-hidden="true">·</span>
      <span><em>Signed</em> &amp; offline-verifiable — tamper-evident, human-gated</span>
    </p>
    <p class="pitch">
      Corral is the reactive audit you put <em>downstream</em> of every AI coding
      tool — agnostic to whoever, or whatever, wrote the change. It mutates the
      code to plant real faults and checks whether the developer's own tests
      catch them — a test that catches nothing proves nothing — while
      a <em>decorrelated</em> critic, a different model than the one that wrote the
      exposing test, reads the suite for theater. The verdict is <em>measured by
      execution in a jail, never taken on a model's word</em>. Any model, local
      7B to frontier, mixed in one run. Human-gated and fail-closed; every run
      recorded, replayable, and signed into a record you verify offline. (Honest
      floor: <code>corral certify</code> is the shipped atom; the adversarial
      pool is experimental and off by default; the broader engine is ahead —
      we'll always tell you which.)
    </p>
    <p class="star-invite">
      Free, source-available, and getting better with every run —
      <a href="https://github.com/pdbethke/corralai">a star helps other people find it</a>.
    </p>
  </div>
</section>

<style>
  #hero { position: relative; }
  .hero-copy { max-width: 860px; margin: 0 auto; padding: 0 20px; text-align: center; }
  /* Visual-first: a compact headline block above the cockpit (so the live
     instrument is what you see first), and the deep copy below it. */
  .hero-top { padding-top: 40px; padding-bottom: 18px; }
  .hero-bottom { padding-top: 26px; padding-bottom: 8px; }
  .hero-copy h1 { font-size: 2.7rem; line-height: 1.12; margin: 0 0 6px; color: var(--amber); }
  /* the Latin original of the maxim, under its translation */
  .latin { color: var(--muted); font-size: 1.05rem; letter-spacing: 0.02em; margin: 0 0 16px; }
  /* Product cockpit chrome that's dead/broken on a static replay (cockpitView
     doesn't manage these): #tab-records is hardcoded active and never toggled
     off (so it looks perpetually selected, "the same link" as corral); #tab-launch
     is the retired builder's composer; #tab-lookbook isn't a replay view. #skinsub
     is the skin subtitle the tab row clips to a meaningless "— the". Hide them on
     the site; the product UI keeps them. */
  :global(#stage-frame #tab-records),
  :global(#stage-frame #tab-launch),
  :global(#stage-frame #tab-lookbook),
  :global(#stage-frame #skinsub) { display: none !important; }
  .lead { font-size: 1.18rem; color: var(--fg); max-width: 720px; margin: 0 auto 18px; line-height: 1.5; }
  .pitch { font-size: 1.02rem; color: var(--fg); max-width: 740px; margin: 0 auto 14px; line-height: 1.6; }
  .proof-row { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; color: var(--fg); font-size: 0.95rem; font-weight: 600; margin: 0 0 10px; }
  .proof-row span[aria-hidden] { color: var(--muted); font-weight: 400; }
  .caption { color: var(--muted); font-size: 0.9rem; margin-bottom: 20px; }
  .ctas { display: flex; gap: 12px; justify-content: center; }
  .cta { background: var(--amber); color: #fff; padding: 10px 20px; border-radius: 6px; font-weight: 600; text-decoration: none; }
  .cta.secondary { background: var(--panel); color: var(--fg); border: 1px solid var(--line); }
  .star-invite { color: var(--muted); font-size: 0.85rem; margin-top: 14px; }
  /* The framed dark viewport: grass, rain, and glowing nodes need a dark
     canvas even on a light page — bordered and shadowed so it reads as a
     window onto the corral, not an unstyled leftover dark section. The
     #replay control bar underneath stays on the same --stage-* tokens so
     the whole player (canvas + controls) reads as one dark instrument.
     Task 1 (the "wow cockpit"): the hero now shows the FULL cockpit — tasks,
     canvas, agents+findings, and the exec console — not a bare canvas, using
     the exact same #cockpit grid shape as /recordings (site/src/pages/
     recordings.astro), just narrower to match the hero's own max-width. The
     four panels themselves are the shared markup from internal/ui/web/
     cockpit-shell.html (via site/src/lib/cockpitShell.ts) — this file only
     owns the surrounding grid/theming, same split as recordings.astro. */
  #stage-frame { max-width: 1040px; margin: 0 auto; padding: 0 20px; }
  #cockpit {
    display: grid; grid-template-columns: 200px 1fr 240px; position: relative;
    /* Bound the cockpit body to the stage's own height so the left task list
       and right roster/findings columns SCROLL inside a fixed viewport rather
       than growing the whole page as the task count climbs (63+ on a real
       run). The row tracks the stage's own max(60vh, 380px). */
    grid-template-rows: minmax(380px, 60vh);
    background: var(--stage-bg); border: 1px solid var(--stage-line); border-top: none;
    box-shadow: 0 18px 44px rgba(30,20,0,.22); overflow: hidden;
  }
  /* Tab-switched view panels overlay the whole cockpit body (below the HUD),
     driven by the shared cockpitView() in replay-player.js. Hidden until their
     tab is selected; the swarm/replay stage keeps running underneath. */
  :global(#cockpit .cview) { display: none; }
  :global(#cockpit .cview.show) {
    display: block; position: absolute; inset: 0; z-index: 6; overflow: auto;
    background: var(--stage-bg); color: var(--stage-fg); padding: 16px 18px;
    font-size: 13px; line-height: 1.5;
  }
  :global(#cockpit .cv-pane) { max-width: 760px; }

  /* the "tests" (audit) lens — renderReplayTests renders the graded suite,
     the surviving fault (fault-highlight), the handed-back test + the verdict
     into #files when the run is a pool audit (not a build). */
  :global(#cockpit .tests-lens .tests-sec) { color: var(--stage-amber,#e8a838); font-size: 11px; text-transform: uppercase; letter-spacing: .5px; margin: 16px 0 6px; }
  :global(#cockpit .tests-lens .tests-note) { color: var(--stage-muted,#8a8170); text-transform: none; letter-spacing: 0; font-size: 11.5px; }
  :global(#cockpit .tests-lens .tests-code) { max-height: 240px; overflow: auto; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11.5px; line-height: 1.5; color: var(--stage-fg,#e6e1d8); background: var(--stage-bg,#0e1116); border: 1px solid var(--stage-line,#33405a); border-radius: 6px; padding: 8px; white-space: pre-wrap; overflow-wrap: anywhere; margin: 0; }
  :global(#cockpit .tests-lens .tests-verdict) { font-weight: 600; padding: 8px 10px; border-radius: 6px; border-left: 3px solid var(--stage-line,#33405a); }
  :global(#cockpit .tests-lens .tv-ok) { color: var(--stage-green,#8fdcab); border-left-color: var(--stage-green,#8fdcab); }
  :global(#cockpit .tests-lens .tv-review) { color: var(--stage-red,#e8503a); border-left-color: var(--stage-red,#e8503a); }
  :global(#cockpit .tests-lens .tests-models) { color: var(--stage-muted,#8a8170); font-size: 11.5px; margin-top: 4px; }
  :global(#cockpit .tests-lens .faultline) { background: rgba(232,80,58,.32); color: #ff7a63; font-weight: 700; border-radius: 3px; padding: 0 2px; }
  :global(#cockpit .cv-mission), :global(#cockpit .cv-prop), :global(#cockpit .cv-hub) {
    border: 1px solid var(--stage-line); border-radius: 8px; padding: 12px 14px; margin-bottom: 12px; background: var(--stage-panel);
  }
  :global(#cockpit .cv-mhdr) { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; }
  :global(#cockpit .cv-dir), :global(#cockpit .cv-sig) { font-weight: 600; color: var(--stage-fg); }
  :global(#cockpit .cv-pill) { font-size: 11px; padding: 1px 8px; border-radius: 999px; text-transform: uppercase; letter-spacing: .5px; }
  :global(#cockpit .cv-pill.done) { background: #1f6f2e; color: #d6ffdf; }
  :global(#cockpit .cv-pill.run) { background: var(--stage-amber); color: var(--stage-bg); }
  :global(#cockpit .cv-sum) { color: var(--stage-muted); margin-bottom: 10px; }
  :global(#cockpit .cv-step), :global(#cockpit .cv-agent), :global(#cockpit .cv-memrow), :global(#cockpit .cv-skrow) {
    display: flex; align-items: baseline; gap: 8px; padding: 3px 0; flex-wrap: wrap;
  }
  :global(#cockpit .cv-memrow), :global(#cockpit .cv-skrow) { display: block; padding: 8px 0; border-bottom: 1px solid var(--stage-line); }
  :global(#cockpit .cv-dot) { width: 8px; height: 8px; border-radius: 50%; flex: 0 0 auto; align-self: center; }
  :global(#cockpit .cv-status), :global(#cockpit .cv-role), :global(#cockpit .cv-meta) { color: var(--stage-muted); font-size: 12px; }
  :global(#cockpit .cv-kind) { display: inline-block; font-size: 11px; color: var(--stage-amber); text-transform: uppercase; letter-spacing: .5px; margin-right: 8px; }
  :global(#cockpit .cv-explain), :global(#cockpit .cv-note), :global(#cockpit .cv-tsum) { color: var(--stage-muted); font-size: 12px; margin-bottom: 12px; }
  :global(#cockpit .cv-note) { margin-top: 12px; }
  /* files lens — tree nodes injected at RUNTIME by renderReplayFiles carry no
     Astro scope attribute, so these MUST be :global (same as .arow/.feedhdr). */
  :global(#cockpit .ft-note) { color: var(--stage-muted); font-size: 12px; margin: 0 0 12px; }
  :global(#cockpit .ft-empty) { color: var(--stage-muted); font-size: 13px; font-style: italic; padding: 8px 0; }
  :global(#cockpit .ft-tree) { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12.5px; line-height: 1.65; }
  :global(#cockpit .ft-row) { display: flex; align-items: center; gap: 7px; white-space: nowrap; }
  :global(#cockpit .ft-dir) { color: var(--stage-muted); }
  :global(#cockpit .ft-caret) { color: var(--stage-muted); font-size: 10px; }
  :global(#cockpit .ft-dname) { color: var(--stage-fg); font-weight: 600; }
  :global(#cockpit .ft-badge) { color: var(--stage-amber); font-size: 10.5px; margin-left: 6px; }
  :global(#cockpit .ft-dot) { width: 9px; height: 9px; border-radius: 2px; flex: 0 0 auto; box-sizing: border-box; }
  :global(#cockpit .ft-who) { color: var(--stage-muted); font-size: 11px; margin-left: 6px; }
  :global(#cockpit .ft-file.ft-released) { opacity: .6; }
  :global(#cockpit .cv-count) { margin-left: auto; color: var(--stage-muted); font-size: 12px; }
  :global(#cockpit .cv-sample) {
    display: inline-block; font-size: 10px; text-transform: uppercase; letter-spacing: .6px;
    background: var(--stage-line); color: var(--stage-fg); border-radius: 4px; padding: 1px 6px; margin-right: 8px; vertical-align: middle;
  }
  :global(#cockpit .cv-pactions button) { margin-right: 8px; margin-top: 8px; font-size: 12px; padding: 3px 10px; border-radius: 5px; border: 1px solid var(--stage-line); background: var(--stage-panel); color: var(--stage-muted); opacity: .6; }
  :global(#stage-frame #hud) {
    position: relative; inset: auto; height: 42px; display: flex; align-items: baseline; gap: 14px;
    padding: 10px 14px; background: var(--stage-bg); color: var(--stage-fg);
    border: 1px solid var(--stage-line); border-bottom: 1px solid var(--stage-line);
    border-top-left-radius: 12px; border-top-right-radius: 12px;
    box-sizing: border-box;
  }
  :global(#stage-frame #hud b) { font-size: 16px; letter-spacing: .5px; color: var(--stage-amber); }
  :global(#stage-frame #hud .sub), :global(#stage-frame #hud .stat) { color: var(--stage-muted); font-size: 14px; }
  :global(#stage-frame #hud .stat) { margin-left: auto; }
  :global(#stage-frame #hud .tab) { color: var(--stage-muted); text-decoration: none; cursor: pointer; padding: 2px 6px; border-radius: 4px; font-size: 14px; }
  :global(#stage-frame #hud .tab.active) { color: var(--stage-bg); background: var(--stage-amber); pointer-events: none; }
  :global(#stage-frame #hud .tab:hover:not(.active)) { color: var(--stage-fg); }
  :global(#stage-frame #hud select) { background: var(--stage-panel); color: var(--stage-fg); border: 1px solid var(--stage-line); border-radius: 6px; font-size: 11px; padding: 2px 4px; cursor: pointer; }
  /* The ☾ theme toggle is a product feature: it toggles html.light, which the
     product's CSS keys off. The marketing site themes via prefers-color-scheme
     (OS) and its cockpit is deliberately dark-always (like the product's canvas
     even in light mode), so the button is a no-op here — hide it rather than
     ship a dead control. */
  :global(#stage-frame #hud #themebtn) { display: none; }
  /* On narrow screens the cockpit stacks to a single column, so drop the fixed
     body-height track and let each panel keep its own scroll cap instead. */
  @media (max-width: 860px) { #cockpit { grid-template-columns: 1fr; grid-template-rows: none; } .cockpit-tasks, .cockpit-side { max-height: 180px; } }
  #stage { position: relative; height: 60vh; min-height: 380px; background: var(--stage-panel); }
  .cockpit-tasks, .cockpit-side {
    background: var(--stage-bg); color: var(--stage-fg); overflow-y: auto;
    /* min-height:0 lets these grid items shrink below their content so the
       overflow-y scroll actually engages inside the bounded row. */
    min-height: 0;
    padding: 10px 12px; font-size: 12px; border-right: 1px solid var(--stage-line);
  }
  /* the right column stacks the agents roster over the findings panel, same
     as the product UI's own #rightcol (internal/ui/web/index.html). */
  .cockpit-side { border-right: none; border-left: 1px solid var(--stage-line); padding: 0; }
  .cockpit-agents, .cockpit-findings { padding: 10px 12px; }
  .cockpit-agents { border-bottom: 1px solid var(--stage-line); }
  /* The panel CONTENT (.arow/.feedhdr/.xblk/.trow/.frow …) is injected at
     RUNTIME by the shared replay renderer (replay-player.js), so those
     elements never carry Astro's scope attribute — the rules MUST be
     :global or they silently don't apply. */
  :global(.arow), :global(#cockpit .arow), :global(#agents .arow), :global(.cockpit-agents .arow) { display: flex; align-items: baseline; gap: 6px; padding: 2px 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  :global(.adot), :global(#cockpit .adot), :global(#agents .adot), :global(.cockpit-agents .adot) { flex: none; align-self: center; width: 7px; height: 7px; border-radius: 50%; }
  :global(.ameta), :global(#cockpit .ameta), :global(#agents .ameta), :global(.cockpit-agents .ameta) { color: var(--stage-muted); font-size: 11px; }
  :global(.adoing), :global(#cockpit .adoing), :global(#agents .adoing), :global(.cockpit-agents .adoing) { color: var(--stage-muted); font-size: 11px; margin-left: auto; padding-left: 10px; overflow: hidden; text-overflow: ellipsis; font-family: ui-monospace, monospace; }
