---
// SPDX-License-Identifier: Elastic-2.0

// Real signed verdicts from the recordings gallery — each row links to its
// replayable tape (/recordings/#<slug>). Kill counts + status mirror each
// tape's signed pool_verdict; keep them in sync when a recording is re-recorded.
// Rendered as plain theme-aware HTML/CSS: no images, no external requests,
// nothing to fetch (the site's test-enforced zero-external-requests posture).
const audits = [
  { lang: 'Python',     target: 'more-itertools · recipes.py',          slug: 'more-itertools-reliable-critic', status: 'certified',   killed: 18, total: 20, note: "a library we didn't write — 2 survivors disclosed" },
  { lang: 'TypeScript', target: 'vercel/ms · index.ts',                 slug: 'vercel-ms-audit',                status: 'needs-review', killed: 4,  total: 5,  note: '1 goal-violating edit the suite missed' },
  { lang: 'Go',         target: 'google/uuid · version4.go',            slug: 'google-uuid-audit',              status: 'needs-review', killed: 13, total: 20, note: '7 survivors — real gaps handed back' },
  { lang: 'Ruby',       target: 'threedaymonk/text · levenshtein.rb',   slug: 'ruby-levenshtein-audit',         status: 'needs-review', killed: 3,  total: 5,  note: '100%-green suite, 60% kill-rate' },
  { lang: 'Go',         target: 'corral · internal/fence.go',           slug: 'pool-fence-crossvendor',         status: 'needs-review', killed: 3,  total: 4,  note: 'cross-vendor herd: Claude + Gemini' },
  { lang: 'Python',     target: 'passwd validator (toy)',               slug: 'passwd-python-audit',            status: 'needs-review', killed: 0,  total: 5,  note: 'a length-only test catches nothing' },
];
---
<section class="section wide" id="proof-band">
  <h2>Six real audits, six signed verdicts</h2>
  <p class="lede">
    We pointed corral at real code across four languages — libraries we didn't
    write, plus our own — and graded each suite <em>by execution</em>: plant
    goal-violating faults, run the developer's <strong>own</strong> tests against
    them in a jail, sign the kill-rate. more-itertools' suite caught 90% and
    <strong>CERTIFIED</strong>. The rest missed enough to be sent back, with the
    gaps named. Every verdict is a signed record you can replay and verify
    offline — pick any row.
  </p>

  <ul class="verdicts" role="list">
    {audits.map((v) => (
      <li>
        <a class={`verdict ${v.status === 'certified' ? 'is-certified' : 'is-review'}`} href={`/recordings/#${v.slug}`}>
          <span class="lang">{v.lang}<span class="target">{v.target}</span></span>
          <span class="pill">{v.status}</span>
          <span class="detail"><strong>{v.killed}/{v.total} killed</strong> · {v.note}</span>
          <span class="replay">replay →</span>
        </a>
      </li>
    ))}
  </ul>

  <div class="cta">
    <p class="cta-label">Run it yourself — one command, off a single <code>ANTHROPIC_API_KEY</code>:</p>
    <pre class="cmd">corral certify --local --code validator.py \
  --goal "reject passwords under 8 chars, or missing a digit or an uppercase letter" \
  -- pytest</pre>
    <p class="cta-foot">
      Every number above is a real signed record you can verify offline —
      <a href="/field-notes/your-tests-suck/">read the write-up →</a>
    </p>
  </div>
</section>

<style>
  .wide { max-width: 1100px; }
  .lede { max-width: 820px; }

  .verdicts { list-style: none; margin: 28px 0 0; padding: 0; display: flex; flex-direction: column; gap: 10px; }
  .verdict {
    display: grid;
    grid-template-columns: 230px 132px 1fr auto;
    align-items: center;
    gap: 14px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-left: 4px solid var(--line);
    border-radius: 10px;
    padding: 14px 18px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.12s ease, transform 0.12s ease;
  }
  .verdict.is-review { border-left-color: var(--amber); }
  .verdict.is-certified { border-left-color: var(--green); }
  .verdict:hover { border-color: var(--fg); transform: translateX(2px); }

  .lang { font-weight: 700; font-size: 1.02rem; color: var(--fg); display: flex; flex-direction: column; gap: 2px; }
  .target { font-weight: 400; font-size: 0.8rem; color: var(--muted); font-family: ui-monospace, monospace; }

  .pill {
    justify-self: start;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 999px;
    border: 1px solid transparent;
    white-space: nowrap;
  }
  .is-review .pill { color: var(--amber); background: var(--sel); border-color: var(--amber); }
  .is-certified .pill { color: var(--green); background: var(--sel); border-color: var(--green); }

  .detail { color: var(--muted); font-size: 0.9rem; }
  .detail strong { color: var(--fg); }

  .replay {
    justify-self: end;
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 600;
  }
  .verdict:hover .replay { color: var(--fg); }

  .cta { margin-top: 28px; }
  .cta-label { margin: 0 0 8px; color: var(--fg); }
  .cta-label code { background: var(--sel); border-radius: 4px; padding: 1px 5px; font-size: 0.85em; }
  .cmd {
    background: var(--panel); border: 1px solid var(--line); border-radius: 8px;
    padding: 14px 18px; overflow-x: auto; font-family: ui-monospace, monospace;
    font-size: 0.85rem; color: var(--fg); margin: 0;
  }
  .cta-foot { margin: 12px 0 0; color: var(--muted); font-size: 0.9rem; }
  .cta-foot a { font-weight: 600; text-decoration: none; }
  .cta-foot a:hover { text-decoration: underline; }

  /* Stack the row on narrow viewports so nothing overflows the page body. */
  @media (max-width: 620px) {
    .verdict { grid-template-columns: 1fr auto; row-gap: 8px; }
    .detail { grid-column: 1 / -1; }
    .replay { justify-self: end; }
  }
</style>
