---
// SPDX-License-Identifier: Elastic-2.0
import '../styles/global.css';
import Hero from '../components/Hero.astro';
import HowItWorks from '../components/HowItWorks.astro';
import ProofBand from '../components/ProofBand.astro';
import LearningLoop from '../components/LearningLoop.astro';
import KnowledgeCorpus from '../components/KnowledgeCorpus.astro';
import WatchItBack from '../components/WatchItBack.astro';
import TeamsInfra from '../components/TeamsInfra.astro';
import Quickstart from '../components/Quickstart.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Header from '../components/Header.astro';

const title = 'Corralai — an audit for software change';
const description = 'Corral certifies a software change by execution: a decorrelated herd of AI agents grades the code and the tests meant to guard it, in a jail, and signs a tamper-evident verdict — any model, human-gated, recorded and replayable. No one is judge in their own cause.';
const ogTitle = 'Corralai — no one is judge in their own cause';
const url = 'https://corralai.dev/';
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <!-- No-flash theme: set data-theme before first paint from saved choice / OS. -->
  <script is:inline>
    (function () { try { var t = localStorage.getItem('corralai-site-theme') || 'light'; document.documentElement.setAttribute('data-theme', t); var ct = localStorage.getItem('corralai-cockpit-theme'); if (ct) document.documentElement.setAttribute('data-cockpit-theme', ct); } catch (e) {} })();
  </script>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={url} />

  <meta property="og:type" content="website" />
  <meta property="og:title" content={ogTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={url} />
  <meta property="og:image" content="https://corralai.dev/og-image.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={ogTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://corralai.dev/og-image.png" />
</head>
<body>
  <Header active="home" />
  <Hero />
  <HowItWorks />
  <ProofBand />
  <LearningLoop />
  <KnowledgeCorpus />
  <WatchItBack />
  <TeamsInfra />
  <Quickstart />
  <SiteFooter />
</body>
</html>
