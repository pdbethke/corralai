---
// SPDX-License-Identifier: Elastic-2.0
import fs from 'node:fs';
import '../styles/global.css';
import { cockpitHud, cockpitViews, cockpitTasks, cockpitAgents, cockpitFindings, cockpitExec } from '../lib/cockpitShell';
import Header from '../components/Header.astro';
import ReplayBarControls from '../components/ReplayBarControls.astro';


// Prefer generated recordings materialized from DuckDB during prebuild; fall
// back to committed JSON tapes when no generated bundle exists.
const generatedStreamModules = import.meta.glob('../data/generated/recordings/*.json', { eager: true });
const legacyStreamModules = import.meta.glob('../data/recordings/*.json', { eager: true });
const hasGeneratedStreams = Object.keys(generatedStreamModules).some(
  (p) => p.endsWith('.json') && !p.endsWith('.meta.json'),
);
const streamModules = hasGeneratedStreams ? generatedStreamModules : legacyStreamModules;
// Optional per-recording analysis: a sibling <slug>.analysis.md written in
// the corral's voice from the run's own evidence (feature #41 will have the
// herd draft these from its own tape). Astro's md pipeline renders it at
// build time; the e2e deny-scan glob covers these files like the streams.
const analysisModules = {
  ...import.meta.glob('../data/recordings/*.analysis.md', { eager: true }),
  ...import.meta.glob('../data/generated/recordings/*.analysis.md', { eager: true }),
};
const analyses: Record<string, any> = {};
for (const [p, mod] of Object.entries(analysisModules)) {
  analyses[p.split('/').pop()!.replace(/\.analysis\.md$/, '')] = (mod as any).Content;
}
const streams: Record<string, unknown> = {};
const cards: { slug: string; directive: string; models: string[]; task_count: number; done_task_count: number; finding_count: number; minutes: number; result?: { url: string; label: string }; platform?: string; video?: string }[] = [];

// One quiet line from meta.platform — e.g. "RTX 5070 · Ryzen 9 5900 · 128GB ·
// local ollama". Marketing shorthand for the card; the meta keeps full names.
// Older recordings without a platform field simply omit the line.
function platformLine(p: any): string | undefined {
  if (!p || !p.inference) return undefined;
  const gpu = p.gpu?.replace(/^NVIDIA (GeForce )?|^AMD (Radeon )?/, '').replace(/\s+\d+GB$/, '');
  const cpu = p.cpu?.replace(/^(AMD|Intel(\(R\))?) /, '').replace(/ \d+-Core.*$/, '');
  return [gpu, cpu, p.ram, p.inference].filter(Boolean).join(' · ');
}
for (const [p, mod] of Object.entries(streamModules)) {
  if (p.endsWith('.meta.json')) continue;
  const slug = p.split('/').pop()!.replace(/\.json$/, '');
  const metaMod = streamModules[p.replace(/\.json$/, '.meta.json')] as any;
  if (!metaMod) throw new Error(`recording ${slug} has no .meta.json sidecar`);
  const meta = metaMod.default ?? metaMod;
  // Skip a recording that materialized with zero steps — a broken/empty export
  // (e.g. a pool run that never reached a terminal status) that otherwise
  // renders as a dead "(no directive recorded) · 0 tasks" card.
  if ((meta.task_count || 0) === 0) continue;
  streams[slug] = (mod as any).default ?? mod;
  cards.push({
    slug,
    directive: meta.directive || '(no directive recorded)',
    models: meta.models || [],
    task_count: meta.task_count || 0,
    done_task_count: meta.done_task_count || 0,
    finding_count: meta.finding_count || 0,
    minutes: Math.round((meta.duration_seconds || 0) / 60),
    platform: platformLine(meta.platform),
    // Optional rendered clip: if scripts/capture-recording-video.sh has written
    // site/public/recordings/<slug>.mp4, the card grows a "watch the run" link
    // (a downloadable/embeddable mp4). Existence is checked at build time.
    video: fs.existsSync(`public/recordings/${slug}.mp4`) ? `/recordings/${slug}.mp4` : undefined,
  });
}
// Lead with the real-library tape (more-itertools — a package we didn't write,
// the longest run, with real findings): the most legible "aha" for a first-time
// viewer, and it recognizably audits code that isn't ours. Then the cross-vendor
// mixtape thesis tape, then the rest alphabetically.
const LEAD_ORDER = ['more-itertools-reliable-critic', 'pool-fence-crossvendor'];
const leadRank = (slug: string) => {
  const i = LEAD_ORDER.indexOf(slug);
  return i === -1 ? LEAD_ORDER.length : i;
};
cards.sort((a, b) => leadRank(a.slug) - leadRank(b.slug) || a.slug.localeCompare(b.slug));
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <!-- No-flash theme: set data-theme before first paint from saved choice / OS. -->
  <script is:inline>
    (function () { try { var t = localStorage.getItem('corralai-site-theme') || 'light'; document.documentElement.setAttribute('data-theme', t); var ct = localStorage.getItem('corralai-cockpit-theme'); if (ct) document.documentElement.setAttribute('data-cockpit-theme', ct); } catch (e) {} })();
  </script>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Corralai — recordings</title>
  <meta name="description" content="A gallery of real recorded corral audits — a decorrelated herd grading a change by execution, different model mixes, every one replayable." />
</head>
<body>
  <Header active="recordings" />
  <div class="section">
    <h1>Recordings</h1>
    <p>
      Real audits, recorded. Each is corral <em>certifying a change by
      execution</em>: a <strong>decorrelated</strong> cross-vendor herd plants
      faults in the code, checks whether the developer's own tests catch them,
      and signs a tamper-evident verdict — <em>no one judging their own cause</em>.
      Some clear the bar and certify; some leave too many survivors the suite
      didn't kill and are sent back — corral discloses those for a human to
      judge, it doesn't rule them defects. Both are here, honestly — the gate
      showing its work either way.
    </p>
    <p>
      Every one was exported through the same deny-list + human-manifest privacy
      gate as the landing hero, and is offline-verifiable from its signed record.
      Open the <strong>tests</strong> tab in any replay to see the verdict, the
      code under review with the surviving fault highlighted, and the suite it
      graded. Pick a card to replay it on the corral canvas.
    </p>
    <div class="cards">
      {cards.map((c) => (
        <div class="card" role="button" tabindex="0" data-slug={c.slug}>
          <span class="directive">{c.directive}</span>
          {c.models.length > 0 && <span class="models">{c.models.join(' + ')}</span>}
          <span class="stats">{c.task_count} tasks ({c.done_task_count} done) · {c.finding_count} findings · {c.minutes}m</span>
          {c.platform && <span class="platform">recorded on {c.platform}</span>}
          {analyses[c.slug] && <span class="has-analysis">analysis below ↓</span>}
          {c.video && (
            <a class="video-link" href={c.video} target="_blank" rel="noopener noreferrer">▶ watch the run (mp4)</a>
          )}
        </div>
      ))}
    </div>
    <p class="back"><a href="/">← back to the corral</a></p>
  </div>

  <div id="stage-frame">
    <div class="cockpit-hud" set:html={cockpitHud} />
    <div id="cockpit">
      <aside class="cockpit-tasks" set:html={cockpitTasks} />
      <div id="stage">
        <canvas id="c"></canvas>
        <div id="empty">pick a recording above</div>
      </div>
      <aside class="cockpit-side">
        <div class="cockpit-agents" set:html={cockpitAgents} />
        <div class="cockpit-findings" set:html={cockpitFindings} />
      </aside>
      <div set:html={cockpitViews} />
    </div>
    <div class="cockpit-exec" set:html={cockpitExec} />
    <!-- The scrubber/controls bar is the LAST panel of the instrument, kept
         INSIDE #stage-frame so it shares the exact same content width and
         aligned left/right borders as the console/cockpit above it (a former
         sibling floated 40px wider — the misaligned bottom edge). -->
    <div id="replay">
      <div class="row">
        <span id="replay-title"></span>
        <button id="replay-playbtn" onclick="toggleReplayPlay()">▶ play</button>
        <input type="range" id="replay-scrub" min="0" max="0" value="0" oninput="seekReplay(+this.value)">
        <span id="replay-label">0 / 0</span>
        <ReplayBarControls />
      </div>
    </div>
  </div>

  {Object.keys(analyses).length > 0 && (
    <div class="section" id="analysis-section">
      {Object.entries(analyses).map(([slug, Content]) => (
        <div class="analysis-panel" data-analysis-slug={slug} hidden>
          <h2>Analysis</h2>
          <Content />
        </div>
      ))}
    </div>
  )}

  <div class="section" id="analytics">
    <h2>Across the recordings</h2>
    <p class="how">
      The cross-recording metric for audits isn't a findings table — it's the
      <strong>bug-catching scorecard</strong>: which model actually catches bugs,
      <em>proven by execution</em>, per (model, role). It accrues as audits run —
      a cell stays <em>provisional</em> until it has enough of them, so we don't
      publish a confident number off a handful — and lives at
      <code>corral scorecard</code> / <code>/api/bugcatch</code>, offline-verifiable
      from each signed record. Fugu's routing scores come out of a trained black
      box; this comes out of a test that really ran and really killed a fault.
    </p>
  </div>
</body>
</html>

<style>
  .cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 14px; margin: 20px 0; }
  .card {
    display: flex; flex-direction: column; gap: 8px; text-align: left; cursor: pointer;
    background: var(--panel); border: 1px solid var(--line); border-radius: 10px; padding: 16px;
    font: inherit; color: var(--fg);
  }
  .card:hover, .card.active { border-color: var(--amber); }
  .directive { font-weight: 600; }
  .models { color: var(--amber); font-size: 0.85rem; }
  .stats { color: var(--muted); font-size: 0.85rem; }
  .platform { color: var(--muted); font-size: 0.78rem; }
  .has-analysis { color: var(--amber); font-size: 0.78rem; }
  .analysis-panel { border-left: 3px solid var(--amber); padding-left: 16px; }
  .analysis-panel :global(h1), .analysis-panel :global(h2) { font-size: 1.15rem; }
  .analysis-panel :global(p), .analysis-panel :global(li) { color: var(--fg); font-size: 0.95rem; }
  .video-link { color: var(--amber); font-size: 0.85rem; font-weight: 600; text-decoration: none; }
  .video-link:hover { text-decoration: underline; }
  .back { margin-top: 8px; }
  /* full-width dark cockpit viewport — same framing tokens as the hero (Task 1),
     now with the tasks/canvas/findings + console panels joining the stage
     (Task 12) so replay drives the whole viewport, not just the canvas. */
  #stage-frame { max-width: 1240px; margin: 0 auto; padding: 0 20px; }
  #cockpit {
    display: grid; grid-template-columns: 220px 1fr 260px; position: relative;
    /* Bound the cockpit body to the stage's own height so the left task list
       and right roster/findings columns SCROLL inside a fixed viewport rather
       than growing the whole page as the task count climbs (63+ on a real
       run). The row tracks the stage's own max(56vh, 360px). */
    grid-template-rows: minmax(360px, 56vh);
    background: var(--stage-bg); border: 1px solid var(--stage-line); border-top: none;
    box-shadow: 0 18px 44px rgba(30,20,0,.22); overflow: hidden;
  }
  /* Tab-switched view panels overlay the cockpit body, driven by the shared
     cockpitView() in replay-player.js — progress/topology/completed from the
     selected recording's tape, a labeled sample for the never-recorded rest. */
  :global(#cockpit .cview) { display: none; }
  :global(#cockpit .cview.show) {
    display: block; position: absolute; inset: 0; z-index: 6; overflow: auto;
    background: var(--stage-bg); color: var(--stage-fg); padding: 16px 18px;
    font-size: 13px; line-height: 1.5;
  }
  :global(#cockpit .cv-pane) { max-width: 820px; }

  /* the "tests" (audit) lens — renderReplayTests renders the graded suite,
     the surviving fault (fault-highlight), the handed-back test + the verdict
     into #files when the run is a pool audit (not a build). */
  :global(#cockpit .tests-lens .tests-sec) { color: var(--stage-amber,#e8a838); font-size: 11px; text-transform: uppercase; letter-spacing: .5px; margin: 16px 0 6px; }
  :global(#cockpit .tests-lens .tests-note) { color: var(--stage-muted,#8a8170); text-transform: none; letter-spacing: 0; font-size: 11.5px; }
  :global(#cockpit .tests-lens .tests-code) { max-height: 240px; overflow: auto; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11.5px; line-height: 1.5; color: var(--stage-fg,#e6e1d8); background: var(--stage-bg,#0e1116); border: 1px solid var(--stage-line,#33405a); border-radius: 6px; padding: 8px; white-space: pre-wrap; overflow-wrap: anywhere; margin: 0; }
  :global(#cockpit .tests-lens .tests-verdict) { font-weight: 600; padding: 8px 10px; border-radius: 6px; border-left: 3px solid var(--stage-line,#33405a); }
  :global(#cockpit .tests-lens .tv-ok) { color: var(--stage-green,#8fdcab); border-left-color: var(--stage-green,#8fdcab); }
  :global(#cockpit .tests-lens .tv-review) { color: var(--stage-red,#e8503a); border-left-color: var(--stage-red,#e8503a); }
  :global(#cockpit .tests-lens .tests-models) { color: var(--stage-muted,#8a8170); font-size: 11.5px; margin-top: 4px; }
  :global(#cockpit .tests-lens .faultline) { background: rgba(232,80,58,.32); color: #ff7a63; font-weight: 700; border-radius: 3px; padding: 0 2px; }
  :global(#cockpit .cv-mission), :global(#cockpit .cv-prop), :global(#cockpit .cv-hub) {
    border: 1px solid var(--stage-line); border-radius: 8px; padding: 12px 14px; margin-bottom: 12px; background: var(--stage-panel);
  }
  :global(#cockpit .cv-mhdr) { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; }
  :global(#cockpit .cv-dir), :global(#cockpit .cv-sig) { font-weight: 600; color: var(--stage-fg); }
  :global(#cockpit .cv-pill) { font-size: 11px; padding: 1px 8px; border-radius: 999px; text-transform: uppercase; letter-spacing: .5px; }
  :global(#cockpit .cv-pill.done) { background: #1f6f2e; color: #d6ffdf; }
  :global(#cockpit .cv-pill.run) { background: var(--stage-amber); color: var(--stage-bg); }
  :global(#cockpit .cv-sum) { color: var(--stage-muted); margin-bottom: 10px; }
  :global(#cockpit .cv-step), :global(#cockpit .cv-agent) { display: flex; align-items: baseline; gap: 8px; padding: 3px 0; flex-wrap: wrap; }
  :global(#cockpit .cv-memrow), :global(#cockpit .cv-skrow) { display: block; padding: 8px 0; border-bottom: 1px solid var(--stage-line); }
  :global(#cockpit .cv-dot) { width: 8px; height: 8px; border-radius: 50%; flex: 0 0 auto; align-self: center; }
  :global(#cockpit .cv-status), :global(#cockpit .cv-role), :global(#cockpit .cv-meta) { color: var(--stage-muted); font-size: 12px; }
  :global(#cockpit .cv-kind) { display: inline-block; font-size: 11px; color: var(--stage-amber); text-transform: uppercase; letter-spacing: .5px; margin-right: 8px; }
  :global(#cockpit .cv-explain), :global(#cockpit .cv-note), :global(#cockpit .cv-tsum) { color: var(--stage-muted); font-size: 12px; margin-bottom: 12px; }
  :global(#cockpit .cv-note) { margin-top: 12px; }
  :global(#cockpit .cv-whlink) { display: inline-block; margin-top: 4px; color: var(--stage-amber); text-decoration: none; font-weight: 600; white-space: nowrap; }
  :global(#cockpit .cv-whlink:hover) { text-decoration: underline; }
  /* files lens — the tree nodes are injected at RUNTIME by renderReplayFiles
     (replay-player.js), so they carry no Astro scope attribute: these MUST be
     :global or they silently don't apply (same rule as .arow/.feedhdr). */
  :global(#cockpit .ft-note) { color: var(--stage-muted); font-size: 12px; margin: 0 0 12px; }
  :global(#cockpit .ft-empty) { color: var(--stage-muted); font-size: 13px; font-style: italic; padding: 8px 0; }
  :global(#cockpit .ft-tree) { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 12.5px; line-height: 1.65; }
  :global(#cockpit .ft-row) { display: flex; align-items: center; gap: 7px; white-space: nowrap; }
  :global(#cockpit .ft-dir) { color: var(--stage-muted); }
  :global(#cockpit .ft-caret) { color: var(--stage-muted); font-size: 10px; }
  :global(#cockpit .ft-dname) { color: var(--stage-fg); font-weight: 600; }
  :global(#cockpit .ft-badge) { color: var(--stage-amber); font-size: 10.5px; margin-left: 6px; }
  :global(#cockpit .ft-dot) { width: 9px; height: 9px; border-radius: 2px; flex: 0 0 auto; box-sizing: border-box; }
  :global(#cockpit .ft-who) { color: var(--stage-muted); font-size: 11px; margin-left: 6px; }
  :global(#cockpit .ft-file.ft-released) { opacity: .6; }
  :global(#cockpit .cv-count) { margin-left: auto; color: var(--stage-muted); font-size: 12px; }
  :global(#cockpit .cv-sample) {
    display: inline-block; font-size: 10px; text-transform: uppercase; letter-spacing: .6px;
    background: var(--stage-line); color: var(--stage-fg); border-radius: 4px; padding: 1px 6px; margin-right: 8px; vertical-align: middle;
  }
  :global(#cockpit .cv-pactions button) { margin-right: 8px; margin-top: 8px; font-size: 12px; padding: 3px 10px; border-radius: 5px; border: 1px solid var(--stage-line); background: var(--stage-panel); color: var(--stage-muted); opacity: .6; }
  :global(#stage-frame #hud) {
    position: relative; inset: auto; height: 42px; display: flex; align-items: baseline; gap: 14px;
    padding: 10px 14px; background: var(--stage-bg); color: var(--stage-fg);
    border: 1px solid var(--stage-line); border-bottom: 1px solid var(--stage-line);
    border-top-left-radius: 12px; border-top-right-radius: 12px;
    box-sizing: border-box;
  }
  :global(#stage-frame #hud b) { font-size: 16px; letter-spacing: .5px; color: var(--stage-amber); }
  :global(#stage-frame #hud .sub), :global(#stage-frame #hud .stat) { color: var(--stage-muted); font-size: 14px; }
  :global(#stage-frame #hud .stat) { margin-left: auto; }
  :global(#stage-frame #hud .tab) { color: var(--stage-muted); text-decoration: none; cursor: pointer; padding: 2px 6px; border-radius: 4px; font-size: 14px; }
  :global(#stage-frame #hud .tab.active) { color: var(--stage-bg); background: var(--stage-amber); pointer-events: none; }
  :global(#stage-frame #hud .tab:hover:not(.active)) { color: var(--stage-fg); }
  :global(#stage-frame #hud select) { background: var(--stage-panel); color: var(--stage-fg); border: 1px solid var(--stage-line); border-radius: 6px; font-size: 11px; padding: 2px 4px; cursor: pointer; }
  /* The ☾ theme toggle is a product feature (toggles html.light); the site
     themes via prefers-color-scheme and its cockpit is dark-always, so it's a
     no-op here — hide it rather than ship a dead control. */
  :global(#stage-frame #hud #themebtn) { display: none; }
  /* product cockpit chrome that's dead/broken on a static replay (cockpitView
     doesn't manage these): #tab-records (hardcoded active, never toggled off →
     looks perpetually selected), the retired-builder "launch" tab, "lookbook",
     and the skin subtitle the tab row clips to "— the". Hide them (product keeps them). */
  :global(#stage-frame #tab-records),
  :global(#stage-frame #tab-launch),
  :global(#stage-frame #tab-lookbook),
  :global(#stage-frame #skinsub) { display: none; }
  /* On narrow screens the cockpit stacks to a single column, so drop the fixed
     body-height track and let each panel keep its own scroll cap instead. */
  @media (max-width: 900px) { #cockpit { grid-template-columns: 1fr; grid-template-rows: none; } .cockpit-tasks, .cockpit-side { max-height: 200px; } }
  #stage { position: relative; height: 56vh; min-height: 360px; background: var(--stage-panel); }
  .cockpit-tasks, .cockpit-side {
    background: var(--stage-bg); color: var(--stage-fg); overflow-y: auto;
    /* min-height:0 lets these grid items shrink below their content so the
       overflow-y scroll actually engages inside the bounded row. */
    min-height: 0;
    padding: 10px 12px; font-size: 12px; border-right: 1px solid var(--stage-line);
  }
  /* the right column stacks the agents roster over the findings panel — the
     same two panels the product UI shows on the right (agents + findings). */
  .cockpit-side { border-right: none; border-left: 1px solid var(--stage-line); padding: 0; }
  .cockpit-agents, .cockpit-findings { padding: 10px 12px; }
  .cockpit-agents { border-bottom: 1px solid var(--stage-line); }
  /* The panel CONTENT (.arow/.feedhdr/.xblk/.trow/.frow …) is injected at
     RUNTIME by the shared replay renderers, so those elements never carry
     Astro's scope attribute — the rules MUST be :global or they silently
     don't apply (the panels would fall back to inherited tokens + inline
     styles only). The WRAPPER classes above (.cockpit-tasks/.cockpit-side/
     .cockpit-agents/.cockpit-exec) are real template elements owned by this
     page, so their scoped class rules apply normally — the #tasks/#agents/
     #findings/#exec ids INSIDE them come from the shared fragment
     (internal/ui/web/cockpit-shell.html, via site/src/lib/cockpitShell.ts)
     and are targeted with :global for the same reason as the injected
     content classes. */
  :global(.arow), :global(#cockpit .arow), :global(#agents .arow), :global(.cockpit-agents .arow) { display: flex; align-items: baseline; gap: 6px; padding: 2px 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  :global(.adot), :global(#cockpit .adot), :global(#agents .adot), :global(.cockpit-agents .adot) { flex: none; align-self: center; width: 7px; height: 7px; border-radius: 50%; }
  :global(.ameta), :global(#cockpit .ameta), :global(#agents .ameta), :global(.cockpit-agents .ameta) { color: var(--stage-muted); font-size: 11px; }
  :global(.adoing), :global(#cockpit .adoing), :global(#agents .adoing), :global(.cockpit-agents .adoing) { color: var(--stage-muted); font-size: 11px; margin-left: auto; padding-left: 10px; overflow: hidden; text-overflow: ellipsis; font-family: ui-monospace, monospace; }
  .cockpit-exec {
    background: var(--stage-bg); color: var(--stage-fg); border: 1px solid var(--stage-line); border-top: none;
    height: 180px; overflow-y: auto; padding: 10px 14px;
    font-size: 12px;
  }
  /* the cockpit panels reuse the product console's class vocabulary — same
     names the shared renderers emit, styled for the dark stage (global: see note above) */
  :global(.feedhdr), :global(#cockpit .feedhdr), :global(#agents .feedhdr), :global(.cockpit-agents .feedhdr), :global(.cockpit-exec .feedhdr) { color: var(--stage-muted); font-size: 11px; letter-spacing: .4px; margin-bottom: 6px; }
  :global(.cockpit-exec .xblk) { margin-bottom: 3px; }
  :global(.cockpit-exec .xcmdline) { display: flex; align-items: baseline; gap: 7px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; line-height: 1.5; }
  :global(.cockpit-exec .xprompt) { color: var(--stage-amber); }
  :global(.cockpit-exec .xcmd) { font-family: ui-monospace, monospace; color: var(--stage-fg); }
  :global(.cockpit-exec .xbadge) { font-weight: 700; }
  :global(.cockpit-exec .xempty), :global(.cockpit-exec .xcursor) { color: var(--stage-muted); }
  /* thought beats — reasoning must read as visibly distinct from an action
     (see internal/ui/web/replay-player.js's renderReplayLine): italic muted
     text with a 💭 affix, no monospace command chrome or exit badge. Text is
     verbatim from the tape — never truncated/rewritten here. */
  :global(.cockpit-exec .xthoughtline) { white-space: normal; overflow-wrap: anywhere; }
  :global(.cockpit-exec .xthoughtico) { flex: none; opacity: .85; }
  :global(.cockpit-exec .xthoughttext) { color: var(--stage-muted); font-style: italic; font-size: 11.5px; line-height: 1.5; }
  :global(.cockpit-tasks .trow) { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; padding: 2px 4px; border-radius: 5px; }
  /* completed / superseded tasks dim as the tape advances (live on play +
     scrub) — they stay in the list (the scrubber is the temporal truth). */
  :global(.cockpit-tasks .trow.tdim) { opacity: .5; }
  :global(.cockpit-tasks .trow:hover) { background: var(--stage-panel); opacity: 1; }
  :global(.cockpit-tasks .tdot) { display: inline-block; width: 7px; height: 7px; border-radius: 50%; margin-right: 6px; }
  :global(.cockpit-findings .frow) { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; padding: 2px 0; }
  :global(.cockpit-findings .frow.hi) { font-weight: 600; }
  :global(.cockpit-findings .fsev) { font-weight: 700; }
  /* the shared renderers emit var(--green)/--red/--fg/--muted inline — on this
     daylight page those would resolve to light-page tokens inside a dark
     stage, so re-scope them onto the cockpit subtree (CSS inheritance does
     the rest; no renderer change needed). */
  #cockpit, .cockpit-exec {
    --fg: var(--stage-fg); --muted: var(--stage-muted);
    --green: #8fdcab; --red: #e8503a; --amber: var(--stage-amber);
  }
  #c { width: 100%; height: 100%; display: block; }
  #empty { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; color: var(--stage-muted); pointer-events: none; }
  /* Bottom panel of the instrument — a child of #stage-frame, so it inherits
     the same content width (and 20px side gutters) as the console/cockpit and
     its left/right borders line up exactly. No own max-width/margin. */
  #replay {
    position: relative; background: var(--stage-panel); color: var(--stage-fg);
    border: 1px solid var(--stage-line); border-top: none;
    border-bottom-left-radius: 12px; border-bottom-right-radius: 12px;
    padding: 9px 16px;
  }
  #replay .row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  #replay .row button { background: var(--stage-panel); color: var(--stage-fg); border: 1px solid var(--stage-line); border-radius: 5px; padding: 4px 12px; font-size: 12px; cursor: pointer; }
  #replay .row button:hover { border-color: var(--stage-amber); }
  #replay .row select { background: var(--stage-panel); color: var(--stage-fg); border: 1px solid var(--stage-line); border-radius: 5px; padding: 3px 6px; font-size: 12px; }
  #replay .row select:hover { border-color: var(--stage-amber); }
  #replay-scrub { flex: 1; min-width: 160px; }
  #replay-label { color: var(--stage-muted); font-size: 11.5px; min-width: 70px; text-align: center; }
  #replay-title { color: var(--stage-amber); font-size: 12px; font-weight: 600; margin-right: 4px; }
  #analytics table { width: 100%; border-collapse: collapse; margin: 12px 0 28px; }
  #analytics th, #analytics td { text-align: left; padding: 6px 10px; border-bottom: 1px solid var(--line); }
  #analytics .num { text-align: right; font-variant-numeric: tabular-nums; }
  #analytics .barcell { width: 40%; }
  #analytics .bar { height: 12px; background: var(--amber); border-radius: 3px; min-width: 2px; }
  #analytics .how { color: var(--muted); font-size: 0.9rem; }
</style>

<script src="/replay-player.js" is:inline></script>
<script define:vars={{ streams }} is:inline>
  // Same minimal DOM contract as Hero.astro (see replay-player.js's header).
  // Real tabs: cockpitView() (replay-player.js) switches the cockpit to the
  // selected view, reducing the active recording's tape into progress/topology/
  // completed and a labeled sample for the never-recorded memory/skills/
  // proposals — the same shared code the hero uses.
  window.setView = function (v) {
    if (typeof cockpitView === 'function') cockpitView(v);
    // No live brain here — pin #stat to "replaying"; the speed sits in #hud-speed.
    const stat = document.getElementById('stat');
    if (stat) stat.textContent = 'replaying';
  };
  window.addEventListener('DOMContentLoaded', () => {
    const activate = (btn) => {
      document.querySelectorAll('.card.active').forEach((c) => c.classList.remove('active'));
      btn.classList.add('active');
      // Show the selected recording's analysis (if it has one) below the player.
      for (const panel of document.querySelectorAll('.analysis-panel')) {
        panel.hidden = panel.dataset.analysisSlug !== btn.dataset.slug;
      }
      // startReplay already accepts a resolved {events:[...]} object — no
      // player change needed; this is the same call shape as the hero.
      startReplay(streams[btn.dataset.slug]).then(() => {
        // replayPlaying is a top-level `let` in replay-player.js (a classic
        // script, so it lands on window) — guard so switching recordings
        // mid-play never toggles playback OFF.
        if (!window.replayPlaying) toggleReplayPlay();
        document.getElementById('stage-frame').scrollIntoView({ behavior: 'smooth' });
      });
    };
    for (const btn of document.querySelectorAll('.card')) {
      btn.addEventListener('click', (ev) => {
        // A card may carry its own link (e.g. "watch the run" mp4) as a real
        // <a> (for a11y + opening in a new tab) — let its own click through
        // without also triggering the replay.
        if (ev.target.closest('a')) return;
        activate(btn);
      });
      btn.addEventListener('keydown', (ev) => {
        if (ev.key === 'Enter' || ev.key === ' ') { ev.preventDefault(); activate(btn); }
      });
    }
    // Deep link: /recordings/#<slug> (e.g. a homepage proof-band row) opens
    // that recording directly — activate + autoplay + scroll into view.
    const initialSlug = decodeURIComponent((location.hash || '').replace(/^#/, ''));
    if (initialSlug) {
      const target = document.querySelector('.card[data-slug="' + (window.CSS && CSS.escape ? CSS.escape(initialSlug) : initialSlug) + '"]');
      if (target) activate(target);
    }
  });
  // The cockpit HUD's #skinsel calls the shared setSkin, which repaints the
  // whole instrument in the picked visual palette (matrix → green phosphor,
  // etc.) and persists the choice so it carries across the demo. setSkin also
  // clobbers document.title with the product's skin subtitle, so wrap it to
  // restore this page's own title after each pick.
  if (typeof window.setSkin === 'function') {
    const _setSkin = window.setSkin;
    window.setSkin = function (v) { _setSkin(v); document.title = 'Corralai — recordings'; };
  }
  // replay-player.js's setSkin() clobbers document.title at script-load time
  // (same as on the landing page) — restore this page's own title.
  document.title = 'Corralai — recordings';
</script>
